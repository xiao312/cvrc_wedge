FoamFile
{
    version     2.0;
    format      ascii;
    class       volVectorField;
    location    "0";
    object      U;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //
// CVRC Wedge Mesh - Initial Velocity Field
// 
// Boundary conditions for axisymmetric combustor:
//   - wedgeFront/wedgeBack : wedge BC (axisymmetric)
//   - wall                  : no-slip (zero velocity)
//   - axis                  : empty BC (symmetry axis)
//   - oxidizer_inlet        : inlet velocity
//   - fuel_inlet            : inlet velocity
//   - oxidizer_slot_*       : inlet velocity (injection slots)
//   - outlet                : zero gradient
// 
// NOTE: Adjust inlet velocities and directions for your specific case.
//       This is a template file - modify as needed.
// -------------------------------------------------------------------------

dimensions      [0 1 -1 0 0 0 0];  // [m/s]

internalField   uniform (0 0 0);

boundaryField
{
    // ---------------------------------------------------------------------
    // WEDGE BOUNDARIES (front and back)
    // These are the two wedge planes at θ = ±2.5°
    // ---------------------------------------------------------------------
    wedgeFront
    {
        type            wedge;
    }
    wedgeBack
    {
        type            wedge;
    }

    // ---------------------------------------------------------------------
    // SYMMETRY AXIS
    // The axis has 'empty' BC because it's a degenerate line (y=0)
    // The axis faces are degenerate (all points at y≈0)
    // ---------------------------------------------------------------------
    axis
    {
        type            empty;
    }

    // ---------------------------------------------------------------------
    // WALL BOUNDARY
    // No-slip condition on combustor walls
    // ---------------------------------------------------------------------
    wall
    {
        type            noSlip;
    }

    // ---------------------------------------------------------------------
    // INLET BOUNDARIES
    // Adjust velocities for your specific case
    // ---------------------------------------------------------------------
    oxidizer_inlet
    {
        // Example: oxidizer inlet at x = -160 mm
        // Flow direction: +x (into the domain)
        type            fixedValue;
        value           uniform (10 0 0);  // [m/s] - adjust as needed
    }

    fuel_inlet
    {
        // Example: fuel inlet at x = -30 mm
        // Flow direction: +x (into the domain)
        type            fixedValue;
        value           uniform (5 0 0);   // [m/s] - adjust as needed
    }

    oxidizer_slot_1
    {
        // Oxidizer injection slot 1
        type            fixedValue;
        value           uniform (20 0 0);  // [m/s] - adjust as needed
    }

    oxidizer_slot_2
    {
        // Oxidizer injection slot 2
        type            fixedValue;
        value           uniform (20 0 0);  // [m/s] - adjust as needed
    }

    oxidizer_slot_3
    {
        // Oxidizer injection slot 3
        type            fixedValue;
        value           uniform (20 0 0);  // [m/s] - adjust as needed
    }

    // ---------------------------------------------------------------------
    // OUTLET BOUNDARY
    // Zero gradient (fully developed flow assumption)
    // ---------------------------------------------------------------------
    outlet
    {
        type            zeroGradient;
    }
}

