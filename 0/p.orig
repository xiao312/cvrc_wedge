FoamFile
{
    version     2.0;
    format      ascii;
    class       volScalarField;
    location    "0";
    object      p;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //
// CVRC Combustor - Pressure Field
// 
// Initial/boundary conditions for pressure [Pa].
// For low-Mach formulation, pressure is normalized (p_rgh = p - rho*g*h).
// -----------------------------------------------------------------------------

dimensions      [1 -1 -2 0 0 0 0];

internalField   uniform 101325;

boundaryField
{
    // ---------------------------------------------------------------------
    // WEDGE BOUNDARIES
    // ---------------------------------------------------------------------
    wedgeFront
    {
        type            wedge;
    }
    wedgeBack
    {
        type            wedge;
    }

    // ---------------------------------------------------------------------
    // SYMMETRY AXIS
    // ---------------------------------------------------------------------
    axis
    {
        type            empty;
    }

    // ---------------------------------------------------------------------
    // COMBUSTOR WALLS
    // ---------------------------------------------------------------------
    wall
    {
        type            zeroGradient;
    }

    // ---------------------------------------------------------------------
    // OXIDIZER INLET
    // ---------------------------------------------------------------------
    oxidizer_inlet
    {
        type            zeroGradient;
    }

    // ---------------------------------------------------------------------
    // FUEL INLET
    // ---------------------------------------------------------------------
    fuel_inlet
    {
        type            zeroGradient;
    }

    // ---------------------------------------------------------------------
    // OXIDIZER INJECTION SLOTS
    // ---------------------------------------------------------------------
    oxidizer_slot_1
    {
        type            zeroGradient;
    }
    oxidizer_slot_2
    {
        type            zeroGradient;
    }
    oxidizer_slot_3
    {
        type            zeroGradient;
    }

    // ---------------------------------------------------------------------
    // OUTLET
    // ---------------------------------------------------------------------
    outlet
    {
        type            fixedValue;
        value           uniform 101325;
    }
}

// ************************************************************************* //