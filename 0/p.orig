FoamFile
{
    version     2.0;
    format      ascii;
    class       volScalarField;
    location    "0";
    object      p;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //
// CVRC Combustor - Pressure Field
// 
// For low-Mach combustion:
//   - Inlets: zeroGradient (mass flow is specified)
//   - Outlet: totalPressure (more stable than fixedValue for compressible)
// -----------------------------------------------------------------------------

dimensions      [1 -1 -2 0 0 0 0];

internalField   uniform 101325;

boundaryField
{
    wedgeFront
    {
        type            wedge;
    }
    wedgeBack
    {
        type            wedge;
    }

    axis
    {
        type            empty;
    }

    wall
    {
        type            zeroGradient;
    }

    oxidizer_inlet
    {
        type            zeroGradient;
    }

    fuel_inlet
    {
        type            zeroGradient;
    }

    oxidizer_slot_1
    {
        type            zeroGradient;
    }
    oxidizer_slot_2
    {
        type            zeroGradient;
    }
    oxidizer_slot_3
    {
        type            zeroGradient;
    }

    outlet
    {
        type            totalPressure;
        p0              uniform 101325;
        value           uniform 101325;
    }
}

// ************************************************************************* //