FoamFile
{
    version     2.0;
    format      ascii;
    class       volVectorField;
    location    "0";
    object      U;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //
// CVRC Combustor - Velocity Field
// 
// Boundary conditions:
//   - oxidizer_inlet: 100 m/s in +x direction (axial)
//   - fuel_inlet: 33 m/s in +y direction (radial, from axis outward)
//   - walls: no-slip (adiabatic)
//   - outlet: pressureInletOutletVelocity
// -----------------------------------------------------------------------------

dimensions      [0 1 -1 0 0 0 0];

internalField   uniform (0 0 0);

boundaryField
{
    wedgeFront
    {
        type            wedge;
    }
    wedgeBack
    {
        type            wedge;
    }

    axis
    {
        type            empty;
    }

    wall
    {
        type            noSlip;
    }

    // Hot oxidizer: 100 m/s axial (+x direction)
    oxidizer_inlet
    {
        type            fixedValue;
        value           uniform (100 0 0);
    }

    // Fuel inlet: 33 m/s radial (+y direction, from axis outward)
    fuel_inlet
    {
        type            fixedValue;
        value           uniform (0 33 0);
    }

    // Oxidizer slots treated as walls (no active injection)
    oxidizer_slot_1
    {
        type            noSlip;
    }
    oxidizer_slot_2
    {
        type            noSlip;
    }
    oxidizer_slot_3
    {
        type            noSlip;
    }

    outlet
    {
        type            pressureInletOutletVelocity;
        inletValue      uniform (0 0 0);
        value           uniform (0 0 0);
    }
}

// ************************************************************************* //