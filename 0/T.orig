FoamFile
{
    version     2.0;
    format      ascii;
    class       volScalarField;
    location    "0";
    object      T;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //
// CVRC Combustor - Temperature Field
// 
// Boundary conditions:
//   - oxidizer_inlet: 1029 K (hot oxidizer)
//   - fuel_inlet: 300 K (adjust as needed)
//   - oxidizer_slots: 1029 K (same as main oxidizer)
//   - outlet: zero gradient
//   - walls: zero gradient (adiabatic)
// -----------------------------------------------------------------------------

dimensions      [0 0 0 1 0 0 0];

internalField   uniform 300;

boundaryField
{
    wedgeFront
    {
        type            wedge;
    }
    wedgeBack
    {
        type            wedge;
    }

    axis
    {
        type            empty;
    }

    wall
    {
        type            zeroGradient;
    }

    // Hot oxidizer: 1029 K, 58% H2O, 42% O2
    oxidizer_inlet
    {
        type            fixedValue;
        value           uniform 1029;
    }

    // Fuel inlet: 300 K (pure CH4)
    fuel_inlet
    {
        type            fixedValue;
        value           uniform 300;
    }

    // Oxidizer slots: same as main oxidizer
    oxidizer_slot_1
    {
        type            fixedValue;
        value           uniform 1029;
    }
    oxidizer_slot_2
    {
        type            fixedValue;
        value           uniform 1029;
    }
    oxidizer_slot_3
    {
        type            fixedValue;
        value           uniform 1029;
    }

    outlet
    {
        type            zeroGradient;
    }
}

// ************************************************************************* //