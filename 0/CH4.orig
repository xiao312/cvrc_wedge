FoamFile
{
    version     2.0;
    format      ascii;
    class       volScalarField;
    location    "0";
    object      CH4;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //
// CVRC Combustor - Methane Mass Fraction
// 
// Boundary conditions:
//   - oxidizer_inlet: Y_CH4 = 0 (no methane in oxidizer)
//   - fuel_inlet: Y_CH4 = 1.0 (pure methane)
//   - oxidizer_slots: Y_CH4 = 0 (no methane in slots)
// -----------------------------------------------------------------------------

dimensions      [0 0 0 0 0 0 0];

internalField   uniform 0;

boundaryField
{
    wedgeFront
    {
        type            wedge;
    }
    wedgeBack
    {
        type            wedge;
    }

    axis
    {
        type            empty;
    }

    wall
    {
        type            zeroGradient;
    }

    // Hot oxidizer: 58% H2O, 42% O2 (no methane)
    oxidizer_inlet
    {
        type            fixedValue;
        value           uniform 0;
    }

    // Fuel inlet: pure methane
    fuel_inlet
    {
        type            fixedValue;
        value           uniform 1.0;
    }

    oxidizer_slot_1
    {
        type            fixedValue;
        value           uniform 0;
    }
    oxidizer_slot_2
    {
        type            fixedValue;
        value           uniform 0;
    }
    oxidizer_slot_3
    {
        type            fixedValue;
        value           uniform 0;
    }

    outlet
    {
        type            zeroGradient;
    }
}

// ************************************************************************* //