FoamFile
{
    version     2.0;
    format      ascii;
    class       dictionary;
    location    "system";
    object      fvSolution;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //
// CVRC Combustor - Finite Volume Solution for dfHighSpeedFoam
// -----------------------------------------------------------------------------

solvers
{
    U
    {
        solver          PBiCGStab;
        preconditioner  DIC;
        tolerance       1e-11;
        relTol          0;
    }

    h
    {
        $U;
        tolerance       1e-11;
        relTol          0;
    }

    ea
    {
        $U;
        tolerance       1e-11;
        relTol          0;
    }

    "rho.*"
    {
        solver          diagonal;
    }

    "(O2|N2|H2O|CH4|Yi)"
    {
        solver          PBiCGStab;
        preconditioner  DILU;
        tolerance       1e-11;
        relTol          0;
    }
}

CENTRAL
{
}

