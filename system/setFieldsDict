FoamFile
{
    version     2.0;
    format      ascii;
    class       dictionary;
    object      setFieldsDict;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

// GENTLE initialization: set T and species only, let velocity develop from BCs
// This avoids creating pressure waves from impulsive velocity fields

defaultFieldValues
(
    volScalarFieldValue T    300
    volScalarFieldValue CH4  0
    volScalarFieldValue O2   0.233
    volScalarFieldValue H2O  0
    volScalarFieldValue N2   0.767
);

regions
(
    // ── Oxidizer passage: T + species only, NO velocity ──
    boxToCell
    {
        box (-0.165 -0.001 -0.01) (-0.009 0.010300 0.01);
        fieldValues
        (
            volScalarFieldValue T    1029
            volScalarFieldValue O2   0.42
            volScalarFieldValue H2O  0.58
            volScalarFieldValue N2   0
            volScalarFieldValue CH4  0
        );
    }

    // ── Fuel pipe: T + species only, NO velocity ──
    boxToCell
    {
        box (-0.031 0.010200 -0.01) (0.001 0.01160 0.01);
        fieldValues
        (
            volScalarFieldValue T    300
            volScalarFieldValue CH4  1.0
            volScalarFieldValue O2   0
            volScalarFieldValue H2O  0
            volScalarFieldValue N2   0
        );
    }
);

