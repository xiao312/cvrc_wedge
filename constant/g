FoamFile
{
    version     2.0;
    format      ascii;
    class       uniformDimensionedVectorField;
    location    "constant";
    object      g;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //
// CVRC Combustor - Gravity
// 
// Standard gravity for combustion simulations.
// -----------------------------------------------------------------------------
// Note: For axisymmetric wedge mesh, gravity direction should be set based on
// your coordinate system. The CVRC combustor is typically oriented with:
//   - x-axis: axial direction (flow direction)
//   - y-axis: radial direction (perpendicular to axis)
//   - z-axis: tangential direction (wedge)
// Gravity in the radial direction (y) for natural convection effects,
// or set to (0 0 0) if natural convection is not considered.
// -----------------------------------------------------------------------------

dimensions      [0 1 -2 0 0 0 0];
value           (0 0 0);

