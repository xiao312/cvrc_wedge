FoamFile
{
    version          2.0;
    format           ascii;
    class            dictionary;
    location         "constant";
    object           CanteraTorchProperties;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //
// CVRC Combustor - Cantera Torch Properties
// 
// Configuration for dfLowMachFoam solver with Cantera chemistry.
// Uses GRI-Mech 3.0 mechanism for methane-air combustion.
// -----------------------------------------------------------------------------

chemistry       off;

CanteraMechanismFile "gri30.yaml";

transportModel       "Mix";

odeCoeffs
{
    "relTol"         1e-6;
    "absTol"         1e-10;
}

inertSpecie          "N2";

splittingStrategy    off;

TorchSettings
{
    torch            off;
}

loadbalancing
{
    active           true;
    log              false;
    algorithm        allAverage;
}

