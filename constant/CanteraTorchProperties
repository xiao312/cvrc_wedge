FoamFile
{
    version          2.0;
    format           ascii;
    class            dictionary;
    location         "constant";
    object           CanteraTorchProperties;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //
// CVRC Combustor - Cantera Torch Properties for dfHighSpeedFoam
// 
// Hot oxidizer: 58% H2O, 42% O2 (no N2)
// Fuel: pure CH4
// Inert species: N2 (required by GRI-Mech 3.0)
// -----------------------------------------------------------------------------

chemistry            off;

CanteraMechanismFile "gri30.yaml";

transportModel       "Mix";

odeCoeffs
{
    "relTol"         1e-6;
    "absTol"         1e-10;
}

inertSpecie          "N2";

splittingStrategy    off;

TorchSettings
{
    torch            off;
}

loadbalancing
{
    active           true;
    log              false;
    algorithm        allAverage;
}

