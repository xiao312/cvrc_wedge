FoamFile
{
    version     2.0;
    format      ascii;
    class       dictionary;
    location    "constant";
    object      turbulenceProperties;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //
// CVRC Combustor - Turbulence Properties
// 
// k-epsilon turbulence model for RANS simulations.
// For LES, use kEqn or Smagorinsky models instead.
// -----------------------------------------------------------------------------

simulationType  laminar;//RAS;

RAS
{
    RASModel    kEpsilon;
    turbulence  on;
    printCoeffs on;
}

