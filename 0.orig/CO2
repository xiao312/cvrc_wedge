FoamFile
{
    version     2.0;
    format      ascii;
    class       volScalarField;
    location    "0";
    object      CO2;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //
// CVRC Combustor - Default Species Mass Fraction for dfHighSpeedFoam
// -----------------------------------------------------------------------------

dimensions      [0 0 0 0 0 0 0];

internalField   uniform 0.29;

boundaryField
{
    back
    {
        type            wedge;
    }
    front
    {
        type            wedge;
    }

    axis
    {
        type            empty;
    }

    wall
    {
        type            zeroGradient;
    }

    oxidizer_inlet
    {
        type            fixedValue;
        value           uniform 0;
    }

    fuel_inlet
    {
        type            fixedValue;
        value           uniform 0;
    }

    oxidizer_slot_1
    {
        type            zeroGradient;
    }
    oxidizer_slot_2
    {
        type            zeroGradient;
    }
    oxidizer_slot_3
    {
        type            zeroGradient;
    }

    outlet
    {
        type            zeroGradient;
    }
}

