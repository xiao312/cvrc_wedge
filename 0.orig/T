FoamFile
{
    version     2.0;
    format      ascii;
    class       volScalarField;
    location    "0";
    object      T;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //
// CVRC Combustor - Temperature Field for dfHighSpeedFoam
// -----------------------------------------------------------------------------

dimensions      [0 0 0 1 0 0 0];

internalField   uniform 300;

boundaryField
{
    back
    {
        type            wedge;
    }
    front
    {
        type            wedge;
    }

    axis
    {
        type            empty;
    }

    wall
    {
        type            zeroGradient;
    }

    // Hot oxidizer: 1029 K, 58% H2O, 42% O2
    oxidizer_inlet
    {
        type            fixedValue;
        value           uniform 1029;
    }

    // Fuel inlet: 300 K (pure CH4)
    fuel_inlet
    {
        type            fixedValue;
        value           uniform 300;
    }

    oxidizer_slot_1
    {
        type            zeroGradient;
    }
    oxidizer_slot_2
    {
        type            zeroGradient;
    }
    oxidizer_slot_3
    {
        type            zeroGradient;
    }

    outlet
    {
        type            zeroGradient;
    }
}

