FoamFile
{
    version     2.0;
    format      ascii;
    class       volScalarField;
    location    "0";
    object      O2;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //
// CVRC Combustor - Oxygen Mass Fraction for dfHighSpeedFoam
// 
// Hot oxidizer composition (1029 K): 58% H2O, 42% O2 by weight
// -----------------------------------------------------------------------------

dimensions      [0 0 0 0 0 0 0];

internalField   uniform 0.42;

boundaryField
{
    back
    {
        type            wedge;
    }
    front
    {
        type            wedge;
    }

    axis
    {
        type            empty;
    }

    wall
    {
        type            zeroGradient;
    }

    oxidizer_inlet
    {
        type            fixedValue;
        value           uniform 0.42;
    }

    fuel_inlet
    {
        type            fixedValue;
        value           uniform 0;
    }

    oxidizer_slot_1
    {
        type            zeroGradient;
    }
    oxidizer_slot_2
    {
        type            zeroGradient;
    }
    oxidizer_slot_3
    {
        type            zeroGradient;
    }

    outlet
    {
        type            zeroGradient;
    }
}

